# ==================================================
# Configuration (edit values on the right of '=')
# Booleans: true | false
# ==================================================

# [OpenAI]
# OpenAI API key
OPENAI_API_KEY=sk-...
# OpenAI model for general tasks
OPENAI_MODEL=gpt-5-mini

# [Chunking (Agent Z)]
# Target chunk size (chars)
CHUNK_SIZE=1000
# Overlap size (chars)
CHUNK_OVERLAP=200
# Max merges per chunk during coordination
MAX_MERGE_STEPS=8
# Hard limit for chunk size after merges
MAX_MERGED_CHARS=60000

# [Quality Thresholds (Agent C)]
# Auto-pass faithfulness
QUALITY_THRESHOLD_FAITHFULNESS=0.85
# Auto-pass relevancy
QUALITY_THRESHOLD_RELEVANCY=0.85
# Auto-fail faithfulness
QUALITY_THRESHOLD_AUTO_FAIL_FAITHFULNESS=0.60
# Auto-fail relevancy
QUALITY_THRESHOLD_AUTO_FAIL_RELEVANCY=0.60
AGENT_C_DIFFICULTY_MODEL=gpt-5-mini

# [Retry]
# Max retries for generation
MAX_RETRIES=3

# [Generation (Agent B)]
# Questions generated per chunk (legacy)
BATCH_SIZE=10
# Default questions per chunk
NUM_QUESTIONS_PER_CHUNK=5
# Number of answer options per question
NUM_ANSWER_OPTIONS=4
# Expected number of correct options (current support: 1)
NUM_CORRECT_OPTIONS=1
# LLM model for question generation (Agent B)
GENERATION_MODEL=gpt-5.2-2025-12-11
# Max output tokens for generation
GENERATION_MAX_TOKENS=8000
# GPT-5 reasoning effort: low|medium|high
GENERATION_REASONING_EFFORT=low
# Minimum words in tip
TIP_MIN_WORDS=60
# Maximum words in tip
TIP_MAX_WORDS=180

# [Agent B Behavior]
# Enable guardian (evaluate step)
B_ENABLE_GUARDIAN=true
# Allow sequential prev/next expansion
B_ENABLE_SEQUENTIAL_EXPANSION=true
# Allow semantic expansion (FAISS)
B_ENABLE_SEMANTIC_EXPANSION=true
# Global toggle for multi-chunk
B_ENABLE_MULTI_CHUNK=true
# Max expansions per chunk
B_MAX_EXPANSIONS=2

# [BCDE Pipeline]
# Questions per chunk in BCDE pipeline
BCDE_QUESTIONS_PER_CHUNK=1
# Optional path for BCDE chunk usage cache
BCDE_CHUNK_CACHE_PATH=

# [Deduplication]
# Similarity threshold for deduplication
SIMILARITY_THRESHOLD=0.85

# [Rewriter (Agent Z)]
# OpenAI model for rewrite
REWRITER_MODEL=gpt-5-mini
# Rewrite temperature
REWRITER_TEMPERATURE=0.0
# Max output tokens for rewrite
REWRITER_MAX_TOKENS=1200
# Max input chars before autosplit/skip
REWRITER_MAX_INPUT_CHARS=40000
# Parallel rewrite workers per document
REWRITER_CONCURRENCY=3
# Max seconds without progress before aborting rewrite tasks
REWRITER_TIMEOUT_SECONDS=300
# 0 = disable; per-document hard timeout (seconds) for run_rewriter
REWRITER_DOC_TIMEOUT_SECONDS=0
# Timeout (seconds) for Agent Z LLM calls (coordinate/analyze)
AGENT_LLM_TIMEOUT_SECONDS=120
# Reasoning effort for Agent Z LLM calls (gpt-5 only)
AGENT_REASONING_EFFORT=low
# Reasoning effort for rewrite calls (gpt-5 only)
REWRITER_REASONING_EFFORT=low
# Force rewrite on all chunks (Agent Z)
REWRITER_FORCE_REWRITE=true
# Coordination mode for Agent Z (llm|heuristic)
REWRITER_COORDINATION_MODE=llm
# Cache LLM coordination decisions
REWRITER_COORDINATION_CACHE_ENABLE=true
# Save coordination cache every N decisions
REWRITER_COORDINATION_CACHE_EVERY=20
# Save partial cache every N chunks (0 to disable)
REWRITER_PARTIAL_SAVE_EVERY=5

# [Rewriter Pattern Learning]
# Enable learning regex cleanup patterns
REWRITER_PATTERN_ENABLE=true
# Min hits before a pattern is applied
REWRITER_PATTERN_MIN_HITS=2
# Min line length eligible for pattern
REWRITER_PATTERN_MIN_LEN=6
# Max line length eligible for pattern
REWRITER_PATTERN_MAX_LEN=160
# Boundary lines scanned for learning
REWRITER_PATTERN_BOUNDARY_LINES=3
# Override path for pattern registry JSON
REWRITER_PATTERN_PATH=

# [Supabase]
# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co
# Supabase service role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...
