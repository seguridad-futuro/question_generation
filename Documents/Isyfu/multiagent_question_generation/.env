# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                    MULTIAGENT QUESTION GENERATION                            ║
# ║                         Environment Configuration                            ║
# ╠══════════════════════════════════════════════════════════════════════════════╣
# ║  Booleans: true | false                                                      ║
# ║  Edit values on the right side of '='                                        ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                              OPENAI CONFIGURATION                            │
# └──────────────────────────────────────────────────────────────────────────────┘

OPENAI_API_KEY=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
OPENAI_MODEL=gpt-5-mini                     # Model for general tasks


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                              AGENT Z - CHUNKING                              │
# └──────────────────────────────────────────────────────────────────────────────┘

CHUNK_SIZE=2500                             # Target chunk size (chars)
CHUNK_OVERLAP=250                           # Overlap size (chars)
MAX_MERGE_STEPS=12                          # Max merges per chunk during coordination
MAX_MERGED_CHARS=80000                      # Hard limit for chunk size after merges


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                          AGENT C - QUALITY THRESHOLDS                        │
# └──────────────────────────────────────────────────────────────────────────────┘

# --- Auto-pass thresholds ---
QUALITY_THRESHOLD_FAITHFULNESS=0.85
QUALITY_THRESHOLD_RELEVANCY=0.85

# --- Auto-fail thresholds ---
QUALITY_THRESHOLD_AUTO_FAIL_FAITHFULNESS=0.60
QUALITY_THRESHOLD_AUTO_FAIL_RELEVANCY=0.60
AGENT_C_DIFFICULTY_MODEL=gpt-5-mini        # Model for difficulty analysis


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                               RETRY CONFIGURATION                            │
# └──────────────────────────────────────────────────────────────────────────────┘

MAX_RETRIES=3                               # Max retries for generation


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                             AGENT B - GENERATION                             │
# └──────────────────────────────────────────────────────────────────────────────┘

# --- Question Generation ---
BATCH_SIZE=10                               # Questions per chunk (legacy)
NUM_QUESTIONS_PER_CHUNK=5                   # Default questions per chunk
NUM_ANSWER_OPTIONS=4                        # Number of answer options per question (current max: 4)
NUM_CORRECT_OPTIONS=1                       # Expected number of correct options (current support: 1)
GENERATION_MODEL=gpt-5.2-2025-12-11         # Model for question generation (Agent B)
GENERATION_MAX_TOKENS=8000                  # Max output tokens
GENERATION_REASONING_EFFORT=low             # GPT-5 reasoning: low|medium|high

# --- Tip Configuration ---
TIP_MIN_WORDS=60                            # Minimum words in tip
TIP_MAX_WORDS=180                           # Maximum words in tip


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                            AGENT B - BEHAVIOR FLAGS                          │
# └──────────────────────────────────────────────────────────────────────────────┘

B_ENABLE_GUARDIAN=false                     # Enable guardian (evaluate step)
B_ENABLE_SEQUENTIAL_EXPANSION=true          # Allow sequential prev/next expansion
B_ENABLE_SEMANTIC_EXPANSION=true            # Allow semantic expansion (FAISS)
B_ENABLE_MULTI_CHUNK=true                   # Global toggle for multi-chunk
B_PARALLEL_AGENTS=10                        # Parallel B agents (run_bcde_pipeline workers)
B_MAX_EXPANSIONS=2                          # Max expansions per chunk


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                              BCDE PIPELINE                                   │
# └──────────────────────────────────────────────────────────────────────────────┘

BCDE_QUESTIONS_PER_CHUNK=1                  # Questions per chunk in pipeline
BCDE_CHUNK_CACHE_PATH=                      # Optional: chunk usage cache path


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                              DEDUPLICATION                                   │
# └──────────────────────────────────────────────────────────────────────────────┘

SIMILARITY_THRESHOLD=0.85                   # Similarity threshold for dedup


# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                             AGENT Z - REWRITER                               │
# └──────────────────────────────────────────────────────────────────────────────┘

# --- Model ---
REWRITER_MODEL=gpt-5-mini                   # OpenAI model for rewrite

# --- Generation Parameters ---
REWRITER_TEMPERATURE=0.0                    # Rewrite temperature
REWRITER_MAX_TOKENS=8000                    # Max output tokens
REWRITER_MAX_INPUT_CHARS=40000              # Max input chars before autosplit
REWRITER_CONCURRENCY=3                       # Parallel workers per document (reduced to avoid rate limits)
REWRITER_TIMEOUT_SECONDS=60                 # Max seconds without progress before aborting rewrite tasks
REWRITER_DOC_TIMEOUT_SECONDS=0              # 0 = disable; per-document hard timeout (seconds) for run_rewriter
AGENT_LLM_TIMEOUT_SECONDS=60                # Timeout (seconds) for Agent Z LLM calls (coordinate/analyze)
AGENT_REASONING_EFFORT=low                  # Reasoning effort for Agent Z LLM calls (gpt-5 only)
REWRITER_REASONING_EFFORT=low               # Reasoning effort for rewrite calls (gpt-5 only)
REWRITER_FORCE_REWRITE=true                 # Force rewrite on all chunks (Agent Z)
REWRITER_PARTIAL_SAVE_EVERY=2               # Save partial cache every N chunks (0 to disable)
REWRITER_COORDINATION_MODE=llm              # Coordination mode for Agent Z (llm|heuristic)
REWRITER_COORDINATION_CACHE_ENABLE=true
REWRITER_COORDINATION_CACHE_EVERY=5

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │                         REWRITER - PATTERN LEARNING                          │
# └──────────────────────────────────────────────────────────────────────────────┘

REWRITER_PATTERN_ENABLE=true                # Enable learning regex patterns
REWRITER_PATTERN_MIN_HITS=2                 # Min hits before pattern is applied
REWRITER_PATTERN_MIN_LEN=6                  # Min line length for pattern
REWRITER_PATTERN_MAX_LEN=160                # Max line length for pattern
REWRITER_PATTERN_BOUNDARY_LINES=3           # Boundary lines scanned for learning
REWRITER_PATTERN_PATH=                      # Override: pattern registry JSON path
